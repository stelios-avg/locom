# Supabase Configuration (Required)
# Get these from your Supabase project: Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
# MUST be the Publishable / anon key (sb_publishable_... or legacy anon JWT). NEVER put the secret key here — NEXT_PUBLIC_* is visible in the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only. Never use NEXT_PUBLIC_ for this. Never import in client components.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe Configuration (Required if using billing/subscriptions)
# Get these from your Stripe dashboard: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_price_id

# App URL (Required if using billing/subscriptions)
# For development: http://localhost:3000
# For production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps API Key (Optional - for enhanced location features)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Municipality Sync (Optional - for automatic municipality post syncing)
# Only needed if you want to sync posts from municipality feeds
MUNICIPALITY_FEED_URL=https://example.com/feed.xml
MUNICIPALITY_SYNC_SECRET=your_random_secret_key_here
MUNICIPALITY_USER_ID=uuid_of_municipality_user_account
MUNICIPALITY_LOCATION=35.1856,33.3823,Nicosia




